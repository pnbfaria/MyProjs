generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Ticket {
  id                String   @id @default(uuid())
  jiraKey           String   @unique
  jiraId            String   @unique
  summary           String
  description       String   @default("")
  client            String   @default("")
  priority          String
  gravity           String
  status            String
  requestedDate     DateTime
  acknowledgeDate   DateTime?
  resolvedDate      DateTime?
  reporter          String   @default("")
  assignee          String   @default("")
  namirialContacted Boolean  @default(false)
  timeTracking      String?
  lastSyncedAt      DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  alerts Alert[]

  @@index([client])
  @@index([gravity])
  @@index([status])
  @@index([requestedDate])
}

model Alert {
  id               String   @id @default(uuid())
  ticketId         String
  ticket           Ticket   @relation(fields: [ticketId], references: [id])
  type             String
  thresholdPercent Int      @default(75)
  slaDeadline      DateTime
  assignee         String   @default("")
  triggeredAt      DateTime @default(now())
  acknowledged     Boolean  @default(false)
  acknowledgedAt   DateTime?

  @@index([ticketId])
  @@index([acknowledged])
  @@index([triggeredAt])
}

model SyncLog {
  id               String   @id @default(uuid())
  startedAt        DateTime @default(now())
  completedAt      DateTime?
  ticketsProcessed Int      @default(0)
  ticketsCreated   Int      @default(0)
  ticketsUpdated   Int      @default(0)
  errors           String   @default("[]")
  status           String   @default("running")
}
